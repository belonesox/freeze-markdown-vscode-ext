{
	"compilerOptions": {
	  "module": "NodeNext",
	  "moduleResolution": "NodeNext",
	  "target": "es2022",
	  "lib": ["es2022"],
	  "outDir": "dist",
	  "sourceMap": true,
	  "strict": true,
	  "esModuleInterop": true,
	  "skipLibCheck": true
	},
	"include": [
	  "src"
	],
	"exclude": ["node_modules", ".vscode-test"]
  }